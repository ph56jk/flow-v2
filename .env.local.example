# ─── Flow v2: setup 1 lần, các lần sau chỉ việc chạy ────────────────
#
# Copy file này thành ".env.local" trong cùng thư mục (root của repo)
# rồi điền giá trị thật. App tự load khi khởi động (flow_web/main.py
# gọi load_local_env() trong lifespan).
#
# Đây là cơ chế "bền vững" hơn data/state.json — kể cả khi state.json
# bị reset/xoá, các credentials trong .env.local vẫn được nhận diện
# qua fallback `os.getenv(...)` trong service.py.
#
# .env.local đã có trong .gitignore (dòng 4) nên không bị commit nhầm.
#
# ─── Trello ─────────────────────────────────────────────────────────
# Lấy API key + token tại https://trello.com/power-ups/admin/
TRELLO_API_KEY=
TRELLO_TOKEN=

# Board chứa card có ảnh để Auto Trello quét (dán URL hoặc board ID).
TRELLO_BOARD_ID=

# (Tùy chọn) Card mặc định để archive ảnh nếu không pin theo card khác.
TRELLO_CARD_ID=

# (Tùy chọn) List mặc định nếu mỗi job sẽ tạo card mới.
TRELLO_LIST_ID=

# ─── Google Gemini (Prompt Assistant) ───────────────────────────────
# Lấy tại https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Telegram (review pack / approval) ──────────────────────────────
# Tạo bot qua @BotFather, sau đó lấy chat ID bằng @userinfobot.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
